
[
  {
    "origin": ["*"],
    "method": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
    "header": [
      "Content-Type",
      "Authorization",
      "X-Goog-Resumable",
      "X-Goog-Upload-Command",
      "X-Goog-Upload-Offset",
      "X-Goog-Upload-Protocol",
      "X-Goog-Upload-Status"
    ],
    "maxAgeSeconds": 3600,
    "responseHeader": ["Content-Type", "Content-Length", "ETag"]
  }
]
