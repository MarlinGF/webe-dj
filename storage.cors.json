
[
  {
    "origin": ["*"],
    "method": ["GET", "PUT", "POST", "DELETE", "OPTIONS"],
    "header": [
      "Content-Type",
      "Authorization",
      "X-Firebase-Storage-Version",
      "X-Goog-Upload-Protocol",
      "X-Goog-Resumable"
    ],
    "responseHeader": [
      "Content-Type",
      "Content-Range",
      "Content-Length"
    ],
    "maxAgeSeconds": 3600
  }
]
