rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read and write to their own tracks collection
    match /users/{userId}/tracks/{trackId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Users can only list their own tracks
    match /users/{userId}/tracks {
      allow list: if request.auth != null && request.auth.uid == userId;
    }
  }
}
