rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Users can only write to their own folder in storage
    match /users/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Allow public read access to all files so the app can play them.
    match /{allPaths=**} {
      allow read;
    }
  }
}
